# Dataiku Configuration
DATAIKU_URL=https://your-dataiku-instance.company.com
DATAIKU_API_KEY=your_api_key_here
DATAIKU_PROJECT_KEY=YOUR_PROJECT_KEY

# Fabric Configuration
FABRIC_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FABRIC_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FABRIC_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FABRIC_CLIENT_SECRET=your_client_secret_here

# Authentication method: azure_cli, service_principal, managed_identity
FABRIC_AUTH_METHOD=azure_cli

# Migration Settings
MIGRATION_TARGET_DIALECT=tsql
MIGRATION_DEFAULT_STORAGE=lakehouse
MIGRATION_OUTPUT_DIR=./output

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/migration.log

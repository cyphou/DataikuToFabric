[
  {
    "id": "daily_customer_refresh",
    "name": "Daily Customer Refresh",
    "projectKey": "CUSTOMER_ANALYTICS",
    "type": "step_based",
    "active": true,
    "params": {
      "notifyOnFailure": true,
      "notifyOnWarning": false
    },
    "triggers": [
      {
        "type": "temporal",
        "active": true,
        "params": {
          "frequency": "Daily",
          "startFrom": 1690000000000,
          "hour": 6,
          "minute": 0,
          "timezone": "UTC",
          "daysOfWeek": ["MON", "TUE", "WED", "THU", "FRI"]
        }
      }
    ],
    "steps": [
      {
        "name": "Build CUSTOMER_360_VIEW",
        "type": "build_flowitem",
        "params": {
          "builds": [{"type": "DATASET", "itemId": "CUSTOMER_360_VIEW"}],
          "jobType": "RECURSIVE_BUILD"
        }
      },
      {
        "name": "Build customer_features",
        "type": "build_flowitem",
        "params": {
          "builds": [{"type": "DATASET", "itemId": "customer_features"}],
          "jobType": "NON_RECURSIVE_FORCED_BUILD"
        }
      },
      {
        "name": "Clear staging cache",
        "type": "exec_sql",
        "params": {
          "connection": "postgresql_dw",
          "sql": "TRUNCATE TABLE staging.temp_customer_cache"
        }
      },
      {
        "name": "Send completion report",
        "type": "send_report",
        "params": {
          "mail": {
            "to": "data-team@company.com",
            "subject": "Daily Customer Refresh Complete"
          }
        }
      }
    ],
    "versionTag": {
      "versionNumber": 5,
      "lastModifiedBy": {"login": "data_engineer"},
      "lastModifiedOn": 1711152000000
    }
  },
  {
